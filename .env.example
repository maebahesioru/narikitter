# 本番 URL（OG 画像・Stripe リダイレクト・メタデータ用）
# NEXT_PUBLIC_BASE_URL=https://narikitter.vercel.app

# Supabase Postgres（Connect から2本。ホストは同一の aws-*-....pooler.supabase.com）
# クエリに & を含むため DATABASE_URL / DIRECT_URL はダブルクォートで囲むこと。
# P1000 → Database でパスワード再設定。パスワードに @ # 等がある場合は URL エンコード。
# DATABASE_URL=postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-1-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true&sslmode=require
# DIRECT_URL=postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-1-<region>.pooler.supabase.com:5432/postgres?sslmode=require
# db push が無言で止まるときは Session（5432）を DIRECT_URL に入れる（Transaction だけだと固まることがある）。
# DATABASE_URL=
# DIRECT_URL=
# CI: prisma-db-push に DATABASE_URL と DIRECT_URL の両方を Repository secrets で登録。

# セキュリティ（middleware: IP 拒否・OAuth レート制限・HttpOnly デバイス ID）
# SECURITY_IP_BLOCKLIST=198.51.100.0/24,203.0.113.1
# SECURITY_AUTH_WINDOW_MS=900000
# SECURITY_AUTH_POST_PER_WINDOW=25
# SECURITY_AUTH_GET_PER_WINDOW=100

# チャット無料枠（月次・JST）。既定 30
# CHAT_FREE_MONTHLY_LIMIT=30

# 手動で無制限にしたいメール（カンマ区切り・任意）
# PREMIUM_USER_EMAILS=you@example.com

# Stripe（Dashboard → Developers → API keys / Webhooks）
# STRIPE_SECRET_KEY=sk_test_xxx
# STRIPE_WEBHOOK_SECRET=whsec_xxx
# サブスクリプション用 Price ID（Products → 価格）
# STRIPE_PRICE_ID=price_xxx
# Webhook エンドポイント: https://<ドメイン>/api/stripe/webhook
# イベント例: checkout.session.completed, customer.subscription.updated, customer.subscription.deleted

# Google ログイン（Auth.js / next-auth v5）— Google Cloud Console で OAuth クライアント作成
# 承認済みのリダイレクト URI: https://<ドメイン>/api/auth/callback/google および http://localhost:3000/api/auth/callback/google
# AUTH_SECRET=openssl rand -base64 32 で生成した文字列（本番必須）
# AUTH_URL=https://narikitter.vercel.app
# AUTH_GOOGLE_ID=
# AUTH_GOOGLE_SECRET=

# Google AdSense（枠ごとに AdSense 管理画面で表示ユニットを作成し、スロット ID を設定）
# 未設定の枠は表示されません。発行者 IDの既定は layout と同じ ca-pub-9868361167191737（変更時は NEXT_PUBLIC_ADSENSE_CLIENT_ID）
# NEXT_PUBLIC_ADSENSE_DISABLED=1
# NEXT_PUBLIC_ADSENSE_CLIENT_ID=ca-pub-xxxxxxxxxxxxxxxx
# NEXT_PUBLIC_ADSENSE_SLOT_ABOVE_TOOLBAR=
# NEXT_PUBLIC_ADSENSE_SLOT_HEADER_PC=
# NEXT_PUBLIC_ADSENSE_SLOT_HEADER_MOBILE=
# NEXT_PUBLIC_ADSENSE_SLOT_BANNER_320=
# NEXT_PUBLIC_ADSENSE_SLOT_MREC=
# NEXT_PUBLIC_ADSENSE_SLOT_SIDEBAR=
# NEXT_PUBLIC_ADSENSE_SLOT_OVERLAY_MOBILE=
# NEXT_PUBLIC_ADSENSE_SLOT_RIGHT_RAIL=
# 開発時も adsbygoogle を読む（通常は本番のみ）
# NEXT_PUBLIC_ADSENSE_IN_DEV=1
